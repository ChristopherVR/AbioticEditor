<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Platforms>x64</Platforms>
    <RootNamespace>AbioticEditor.Cli</RootNamespace>
    <AssemblyName>abioticeditor</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.CommandLine" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\AbioticEditor.Core\AbioticEditor.Core.csproj" />
    <ProjectReference Include="..\AbioticEditor.Plugins.Abstractions\AbioticEditor.Plugins.Abstractions.csproj" />
    <!-- Updater excluded from the Nexus Mods build (see App csproj for rationale). -->
    <ProjectReference Include="..\AbioticEditor.Updater\AbioticEditor.Updater.csproj"
                      Condition="'$(NexusMods)' != 'true'" />
  </ItemGroup>

  <!-- Nexus Mods build: strip updater by defining NEXUSMODS (-p:NexusMods=true). -->
  <PropertyGroup Condition="'$(NexusMods)' == 'true'">
    <DefineConstants>$(DefineConstants);NEXUSMODS</DefineConstants>
  </PropertyGroup>

  <ItemGroup>
    <!-- Bundled usmap fallback, same convention as the app: a user-supplied
         %LOCALAPPDATA%\AbioticEditor\mappings\Mappings.usmap takes precedence. -->
    <None Include="..\..\assets\Mappings.usmap" Link="Mappings.usmap" CopyToOutputDirectory="PreserveNewest" />

    <!-- Bundled game-data registry (generated by 'dump-registry'), same convention as the app:
         a user-supplied %LOCALAPPDATA%\AbioticEditor\registry\registry.json takes precedence.
         The glob matches nothing until the file is generated, so the build never fails on its
         absence (see GameDataRegistry.LoadBundled). -->
    <None Include="..\..\assets\registry\*.json" Link="registry\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />

    <!-- Bundled wiki images: the offline fallback for fish/vehicle/feature/door pictures
         (generated by 'download-wiki-images'). Copied into a wiki\ subfolder next to the exe,
         where WikiImageCache.BundledDirectory looks for them; the live wiki is still tried first.
         README.md is excluded - only the images ship. -->
    <None Include="..\..\assets\wiki\*" Exclude="..\..\assets\wiki\README.md"
          Link="wiki\%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
