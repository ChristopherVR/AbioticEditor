<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
    Abiotic Factor palette — the game's own UI language: desaturated blue-teal
    facility panes (inventory pane #306481 / outline #5292B7), cyan data readouts
    (#8CFFFB item names), POCKETS-header blue section titles (#71C5F6), hazard
    orange/yellow reserved for calls-to-action and warnings. ThemeService overwrites
    these at startup; the values here are the default (Cascade dark) palette.
    -->

    <!-- Surfaces: deep blue-gray facility chrome -->
    <Color x:Key="AfShellBackground">#081119</Color>
    <Color x:Key="AfPageBackground">#0C1A24</Color>
    <Color x:Key="AfPanelBackground">#132736</Color>
    <Color x:Key="AfPanelElevated">#1B3648</Color>
    <Color x:Key="AfPanelHover">#26475D</Color>
    <Color x:Key="AfDivider">#2E5471</Color>
    <Color x:Key="AfBorderSubtle">#224158</Color>

    <!-- Text: cool white primary, steel-blue secondary -->
    <Color x:Key="AfTextPrimary">#DCEFF9</Color>
    <Color x:Key="AfTextSecondary">#8FB8D0</Color>
    <Color x:Key="AfTextMuted">#587C93</Color>
    <Color x:Key="AfTextOnAccent">#07121A</Color>

    <!-- Accents: GATE hazard orange + caution yellow + cyan terminal readouts -->
    <Color x:Key="AfAccentOrange">#F89A4F</Color>
    <Color x:Key="AfAccentOrangeDim">#B86F33</Color>
    <Color x:Key="AfHazardYellow">#FFE563</Color>
    <Color x:Key="AfTerminalGreen">#7FE9E2</Color>
    <Color x:Key="AfTerminalGreenDim">#3F837E</Color>
    <Color x:Key="AfAlertRed">#E25B4B</Color>
    <Color x:Key="AfAmber">#71C5F6</Color>
    <SolidColorBrush x:Key="AfAmberBrush" Color="{StaticResource AfAmber}" />

    <!-- Brushes -->
    <SolidColorBrush x:Key="AfPageBackgroundBrush" Color="{StaticResource AfPageBackground}" />
    <SolidColorBrush x:Key="AfPanelBackgroundBrush" Color="{StaticResource AfPanelBackground}" />
    <SolidColorBrush x:Key="AfPanelElevatedBrush" Color="{StaticResource AfPanelElevated}" />
    <SolidColorBrush x:Key="AfDividerBrush" Color="{StaticResource AfDivider}" />
    <SolidColorBrush x:Key="AfBorderSubtleBrush" Color="{StaticResource AfBorderSubtle}" />
    <SolidColorBrush x:Key="AfTextPrimaryBrush" Color="{StaticResource AfTextPrimary}" />
    <SolidColorBrush x:Key="AfTextSecondaryBrush" Color="{StaticResource AfTextSecondary}" />
    <SolidColorBrush x:Key="AfAccentOrangeBrush" Color="{StaticResource AfAccentOrange}" />
    <SolidColorBrush x:Key="AfHazardYellowBrush" Color="{StaticResource AfHazardYellow}" />
    <SolidColorBrush x:Key="AfTerminalGreenBrush" Color="{StaticResource AfTerminalGreen}" />
    <SolidColorBrush x:Key="AfAlertRedBrush" Color="{StaticResource AfAlertRed}" />

    <!--
    Legacy keys kept so the default MAUI Styles.xaml resolves cleanly.
    Mapped to AF equivalents so accidental uses still look on-brand.
    -->
    <Color x:Key="Primary">#E37A22</Color>
    <Color x:Key="PrimaryDark">#A85918</Color>
    <Color x:Key="PrimaryDarkText">#E8DEC4</Color>
    <Color x:Key="Secondary">#F2C82E</Color>
    <Color x:Key="SecondaryDarkText">#100E0A</Color>
    <Color x:Key="Tertiary">#7BB351</Color>

    <Color x:Key="White">#E8DEC4</Color>
    <Color x:Key="Black">#100E0A</Color>
    <Color x:Key="Magenta">#E37A22</Color>
    <Color x:Key="MidnightBlue">#1A1812</Color>
    <Color x:Key="OffBlack">#1A1812</Color>

    <Color x:Key="Gray100">#E8DEC4</Color>
    <Color x:Key="Gray200">#C9BFA6</Color>
    <Color x:Key="Gray300">#9F9582</Color>
    <Color x:Key="Gray400">#7C7361</Color>
    <Color x:Key="Gray500">#6E6655</Color>
    <Color x:Key="Gray600">#3D3528</Color>
    <Color x:Key="Gray900">#23201A</Color>
    <Color x:Key="Gray950">#1A1812</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}" />
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}" />
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}" />
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}" />

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}" />
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}" />
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}" />
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}" />
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}" />
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}" />
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}" />
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}" />
</ResourceDictionary>
