<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
    Abiotic Factor visual system. Layered on top of the default MAUI Styles.xaml
    so unstyled controls inherit, and our named styles override where it matters.

    Refinement pass (keep the game theme): calmer button feedback (no hue-jump on hover),
    tighter letter-spacing on headings/labels, a consistent 6px control radius. Performance
    pass: panels carry no GPU drop-shadow, and reveals are a quick fade (see Controls/Fx.cs)
    so navigation stays snappy rather than animating for ~200ms per move.
    -->

    <!-- Shell / page surfaces -->
    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{DynamicResource AfShellBackground}" />
        <Setter Property="Shell.ForegroundColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="Shell.TitleColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>

    <Style TargetType="ContentPage" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{DynamicResource AfPageBackground}" />
    </Style>

    <!-- Default Label: cream on dark, body sans-serif -->
    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="13" />
    </Style>

    <!-- Buttons: chunky hazard-orange CTA. Slight corner rounding keeps the industrial
         terminal feel while reading as a modern control. Pressed state dips scale for
         tactile feedback; 40px minimum height keeps touch targets comfortable. -->
    <Style TargetType="Button">
        <Setter Property="TextColor" Value="{DynamicResource AfTextOnAccent}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource AfAccentOrange}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="CharacterSpacing" Value="0.5" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="MinimumHeightRequest" Value="36" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1" />
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <!-- Hover: a subtle grow + slight brighten, NOT an orange->yellow hue jump
                         (the old flip read as jarring). -->
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1.02" />
                            <Setter Property="Opacity" Value="0.92" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.97" />
                            <Setter Property="BackgroundColor" Value="{DynamicResource AfAccentOrangeDim}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{DynamicResource AfTextMuted}" />
                            <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelElevated}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Activity indicator: terminal green so it reads as "live data" -->
    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{DynamicResource AfTerminalGreen}" />
    </Style>

    <!-- Inputs: consistent dark fields with an amber focus ring -->
    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelElevated}" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource AfTextMuted}" />
        <Setter Property="MinimumHeightRequest" Value="34" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelHover}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelElevated}" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="TitleColor" Value="{DynamicResource AfTextMuted}" />
        <Setter Property="MinimumHeightRequest" Value="34" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelElevated}" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{DynamicResource AfTextMuted}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{DynamicResource AfTerminalGreen}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="ProgressColor" Value="{DynamicResource AfAccentOrange}" />
        <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelElevated}" />
    </Style>

    <!-- ===== Named styles ===== -->

    <Style x:Key="AfH1" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="CharacterSpacing" Value="2" />
    </Style>

    <Style x:Key="AfH2" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="TextColor" Value="{DynamicResource AfAmber}" />
        <Setter Property="CharacterSpacing" Value="1.5" />
    </Style>

    <Style x:Key="AfFieldLabel" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextSecondary}" />
        <Setter Property="CharacterSpacing" Value="1.5" />
    </Style>

    <Style x:Key="AfFieldValue" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
    </Style>

    <Style x:Key="AfReadout" TargetType="Label">
        <!-- Data values rendered in the in-game digital-7 font for a CRT-readout feel. -->
        <Setter Property="FontFamily" Value="Digital7" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="TextColor" Value="{DynamicResource AfTerminalGreen}" />
        <Setter Property="CharacterSpacing" Value="1" />
    </Style>

    <Style x:Key="AfReadoutLarge" TargetType="Label">
        <Setter Property="FontFamily" Value="Digital7" />
        <Setter Property="FontSize" Value="26" />
        <Setter Property="TextColor" Value="{DynamicResource AfTerminalGreen}" />
        <Setter Property="CharacterSpacing" Value="2" />
    </Style>

    <Style x:Key="AfWordmark" TargetType="Label">
        <!-- Used for the title in the branded header; digital-7 reads as the AF brand. -->
        <Setter Property="FontFamily" Value="Digital7" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="CharacterSpacing" Value="6" />
    </Style>

    <Style x:Key="AfMuted" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextSecondary}" />
    </Style>

    <Style x:Key="AfStatusText" TargetType="Label">
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextMuted}" />
        <Setter Property="CharacterSpacing" Value="1" />
    </Style>

    <Style x:Key="AfPanel" TargetType="Border">
        <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelBackground}" />
        <!-- Stroke is Brush-typed: DynamicResource skips the Color->Brush converter,
             so point at the brush resource (ThemeService refreshes brushes too). -->
        <Setter Property="Stroke" Value="{DynamicResource AfBorderSubtleBrush}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 8" />
        <!-- No drop-shadow: WinUI composition shadows are GPU-expensive and re-render on every
             scroll/resize/animation; with ~19 panels on screen that was a real source of jank.
             The panel still reads as a card via its background + 1px border (the ShadCN way). -->
    </Style>

    <!-- Secondary "ghost" button: transparent body, bordered, for non-primary actions -->
    <Style x:Key="AfGhostButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="BorderColor" Value="{DynamicResource AfDivider}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelHover}" />
                            <Setter Property="BorderColor" Value="{DynamicResource AfAccentOrange}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.98" />
                            <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelHover}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Tab strip button: auto-sized chip used inside the horizontally scrollable
         tab bars (selected state comes from the TabBrush-bound BackgroundColor). -->
    <Style x:Key="AfTabButton" TargetType="Button">
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="1.5" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="MinimumHeightRequest" Value="38" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="TextColor" Value="{DynamicResource AfAmber}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.97" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Filter chip: small pill used by category rows -->
    <Style x:Key="AfChipButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelElevated}" />
        <Setter Property="TextColor" Value="{DynamicResource AfTextPrimary}" />
        <Setter Property="BorderColor" Value="{DynamicResource AfBorderSubtle}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="FontSize" Value="9" />
        <Setter Property="CharacterSpacing" Value="1" />
        <Setter Property="Padding" Value="10,3" />
        <Setter Property="MinimumHeightRequest" Value="24" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{DynamicResource AfPanelHover}" />
                            <Setter Property="BorderColor" Value="{DynamicResource AfHazardYellow}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="Scale" Value="0.97" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="AfChrome" TargetType="Border">
        <!-- Top/bottom bars: a subtler, flatter chrome panel -->
        <Setter Property="BackgroundColor" Value="{DynamicResource AfShellBackground}" />
        <Setter Property="Stroke" Value="{DynamicResource AfDividerBrush}" />
        <Setter Property="StrokeThickness" Value="0,0,0,1" />
        <Setter Property="StrokeShape" Value="Rectangle" />
    </Style>

    <!-- Hazard stripe: a stack of slanted yellow/black blocks. Kept as a Style on Grid
         so it can be reused. The Grid expects two same-row BoxViews repeated by the
         caller, but for now a single yellow strip + black border reads as caution. -->
    <Style x:Key="AfHazardStripe" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="3" />
        <Setter Property="BackgroundColor" Value="{DynamicResource AfHazardYellow}" />
    </Style>

    <Style x:Key="AfDivider" TargetType="BoxView">
        <Setter Property="HeightRequest" Value="1" />
        <Setter Property="BackgroundColor" Value="{DynamicResource AfDivider}" />
    </Style>

    <!-- Sidebar item: CollectionView item template root. (HoverLift is intentionally NOT
         applied here: a scale-on-hover forces a per-row relayout, and snappy beats smooth for
         long lists. Fx.HoverLift remains available for opt-in use on small, non-list cards.) -->
    <Style x:Key="AfSidebarItem" TargetType="Grid">
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

</ResourceDictionary>
