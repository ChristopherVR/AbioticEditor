<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.Player.PlayerRawTab"
             x:DataType="vm:MainViewModel">

    <!-- Player RAW JSON tab: export → edit externally → import -->
    <Border Style="{StaticResource AfPanel}" Padding="20,16"

            IsVisible="{Binding PlayerEditor.IsRawTab, FallbackValue=False}">
        <VerticalStackLayout Spacing="14">
            <Label Text="RAW SAVE JSON" Style="{StaticResource AfH2}" FontSize="18" />
            <Label Text="Save JSON is far too large to edit comfortably in-app. EXPORT writes a .json file next to the save and opens it in your default editor; make your changes there, save, then IMPORT to convert it back into the .sav (a .bak backup of the save is kept)."
                   Style="{StaticResource AfMuted}" FontSize="12" />
            <Label Text="{Binding PlayerEditor.JsonPath, StringFormat='JSON file: {0}'}"
                   Style="{StaticResource AfStatusText}" />
            <HorizontalStackLayout Spacing="12">
                <Button Text="EXPORT JSON + OPEN"
                        Command="{Binding PlayerEditor.ExportJsonCommand}" />
                <Button Text="IMPORT JSON → SAVE"
                        BackgroundColor="{StaticResource AfAccentOrange}"
                        TextColor="{StaticResource AfTextOnAccent}"
                        Command="{Binding PlayerEditor.ImportJsonCommand}" />
                <ActivityIndicator IsRunning="{Binding PlayerEditor.IsSaving}"
                                   IsVisible="{Binding PlayerEditor.IsSaving}"
                                   WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Label Text="{Binding PlayerEditor.RawStatus}"
                   Style="{StaticResource AfReadout}" FontSize="13" />
        </VerticalStackLayout>
    </Border>
</ContentView>
