<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.Player.PlayerVitalsTab"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding PlayerEditor.IsVitalsTab, FallbackValue=False}">

    <VerticalStackLayout Spacing="22">

        <!-- Character stats editor (player saves only) -->
        <Border Style="{StaticResource AfPanel}" Padding="20,18"

                IsVisible="{Binding PlayerEditor.IsVitalsTab, FallbackValue=False}">
            <VerticalStackLayout Spacing="14">

                <Label Text="CHARACTER STATS" Style="{StaticResource AfH2}" />

                <BoxView Style="{StaticResource AfDivider}" />

                <!-- Stat sliders -->
                <Grid ColumnDefinitions="110,*,70" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="14" ColumnSpacing="12">

                    <Label Grid.Row="0" Grid.Column="0" Text="HUNGER"      Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding PlayerEditor.Hunger, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAccentOrange}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}"
                            VerticalOptions="Center" />
                    <Label Grid.Row="0" Grid.Column="2" Text="{Binding PlayerEditor.Hunger, StringFormat='{0:F1}'}" Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="1" Grid.Column="0" Text="THIRST"      Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding PlayerEditor.Thirst, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAccentOrange}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}"
                            VerticalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="2" Text="{Binding PlayerEditor.Thirst, StringFormat='{0:F1}'}" Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="2" Grid.Column="0" Text="SANITY"      Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding PlayerEditor.Sanity, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAccentOrange}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}"
                            VerticalOptions="Center" />
                    <Label Grid.Row="2" Grid.Column="2" Text="{Binding PlayerEditor.Sanity, StringFormat='{0:F1}'}" Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="3" Grid.Column="0" Text="FATIGUE"     Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="3" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding PlayerEditor.Fatigue, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAccentOrange}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}"
                            VerticalOptions="Center" />
                    <Label Grid.Row="3" Grid.Column="2" Text="{Binding PlayerEditor.Fatigue, StringFormat='{0:F1}'}" Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="4" Grid.Column="0" Text="CONTINENCE"  Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="4" Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding PlayerEditor.Continence, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAccentOrange}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}"
                            VerticalOptions="Center" />
                    <Label Grid.Row="4" Grid.Column="2" Text="{Binding PlayerEditor.Continence, StringFormat='{0:F1}'}" Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                </Grid>

                <BoxView Style="{StaticResource AfDivider}" />

                <Grid ColumnDefinitions="110,180,*" ColumnSpacing="12">
                    <Label Grid.Column="0" Text="CURRENT MONEY" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" LineBreakMode="WordWrap" />
                    <Entry Grid.Column="1"
                           Text="{Binding PlayerEditor.Money, Mode=TwoWay}"
                           Keyboard="Numeric"
                           FontFamily="Digital7"
                           FontSize="20"
                           TextColor="{StaticResource AfTerminalGreen}"
                           BackgroundColor="{StaticResource AfPanelElevated}" />
                    <Label Grid.Column="2"
                           Text="{Binding PlayerEditor.SaveStatus}"
                           Style="{StaticResource AfMuted}"
                           VerticalOptions="Center"
                           HorizontalTextAlignment="End" />
                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- Body health + heal-all -->
        <Border Style="{StaticResource AfPanel}" Padding="20,16"
                IsVisible="{Binding PlayerEditor.IsVitalsTab, FallbackValue=False}">
            <VerticalStackLayout Spacing="12">
                <!-- Limb health -->
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                    <Label Grid.Column="0" Text="BODY HEALTH" Style="{StaticResource AfFieldLabel}" FontSize="12" TextColor="{StaticResource AfAmber}" CharacterSpacing="5" VerticalOptions="Center" />
                    <Button Grid.Column="1" Text="HEAL ALL"
                            FontSize="10" Padding="10,4"
                            BackgroundColor="{StaticResource AfTerminalGreen}"
                            TextColor="{StaticResource AfTextOnAccent}"
                            Command="{Binding PlayerEditor.HealAllCommand}" />
                </Grid>
                <controls:AdaptiveGrid ColumnDefinitions="90,*,60,40,90,*,60" ColumnSpacing="12"
                                       RowDefinitions="Auto,Auto,Auto" RowSpacing="10" CompactWidth="640">

                    <Label Grid.Row="0" Grid.Column="0" Text="HEAD" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="100"
                            Value="{Binding PlayerEditor.Head, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAlertRed}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}" VerticalOptions="Center" />
                    <Label Grid.Row="0" Grid.Column="2" Text="{Binding PlayerEditor.Head, StringFormat='{0:F0}'}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="0" Grid.Column="4" Text="TORSO" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="0" Grid.Column="5" Minimum="0" Maximum="100"
                            Value="{Binding PlayerEditor.Torso, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAlertRed}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}" VerticalOptions="Center" />
                    <Label Grid.Row="0" Grid.Column="6" Text="{Binding PlayerEditor.Torso, StringFormat='{0:F0}'}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="1" Grid.Column="0" Text="LEFT ARM" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="1" Grid.Column="1" Minimum="0" Maximum="100"
                            Value="{Binding PlayerEditor.LeftArm, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAlertRed}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}" VerticalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="2" Text="{Binding PlayerEditor.LeftArm, StringFormat='{0:F0}'}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="1" Grid.Column="4" Text="RIGHT ARM" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="1" Grid.Column="5" Minimum="0" Maximum="100"
                            Value="{Binding PlayerEditor.RightArm, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAlertRed}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}" VerticalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="6" Text="{Binding PlayerEditor.RightArm, StringFormat='{0:F0}'}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="2" Grid.Column="0" Text="LEFT LEG" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="2" Grid.Column="1" Minimum="0" Maximum="100"
                            Value="{Binding PlayerEditor.LeftLeg, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAlertRed}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}" VerticalOptions="Center" />
                    <Label Grid.Row="2" Grid.Column="2" Text="{Binding PlayerEditor.LeftLeg, StringFormat='{0:F0}'}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />

                    <Label Grid.Row="2" Grid.Column="4" Text="RIGHT LEG" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Slider Grid.Row="2" Grid.Column="5" Minimum="0" Maximum="100"
                            Value="{Binding PlayerEditor.RightLeg, Mode=TwoWay}"
                            MinimumTrackColor="{StaticResource AfAlertRed}"
                            MaximumTrackColor="{StaticResource AfPanelElevated}"
                            ThumbColor="{StaticResource AfTerminalGreen}" VerticalOptions="Center" />
                    <Label Grid.Row="2" Grid.Column="6" Text="{Binding PlayerEditor.RightLeg, StringFormat='{0:F0}'}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" HorizontalTextAlignment="End" />
                </controls:AdaptiveGrid>

            </VerticalStackLayout>
        </Border>
    </VerticalStackLayout>
</ContentView>
