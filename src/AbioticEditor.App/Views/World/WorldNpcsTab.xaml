<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:items="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.World.WorldNpcsTab"
             x:DataType="vm:MainViewModel">

    <!-- ============== TAB: NPCs & traders ============== -->
    <VerticalStackLayout Spacing="12"
                         IsVisible="{Binding WorldEditor.IsNpcsTab}">
        <Label Text="STORY NPCS &amp; TRADERS IN THIS WORLD" Style="{StaticResource AfH2}" FontSize="18" />
        <Label Text="Live story-NPC / trader records in this save. REVIVE brings a removed actor back; the narrative state byte controls their story stage (the game's enum has no readable names - change it only if you know the target stage). Tamed pets now have their own PETS tab."
               Style="{StaticResource AfMuted}" FontSize="11" />
        <Border BackgroundColor="{StaticResource AfShellBackground}"
                Stroke="{StaticResource AfBorderSubtleBrush}"
                StrokeThickness="1" StrokeShape="Rectangle"
                Padding="14,10">
            <VerticalStackLayout Spacing="8"
                                 BindableLayout.ItemsSource="{Binding WorldEditor.Npcs}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="items:WorldNpcViewModel">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto,220" ColumnSpacing="14">
                            <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                                <Label Text="{Binding ActorName}" Style="{StaticResource AfFieldValue}" FontSize="13" />
                                <Label Text="{Binding ContextText}" Style="{StaticResource AfStatusText}" FontSize="9"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding StatusText}"
                                   Style="{StaticResource AfFieldLabel}" VerticalOptions="Center">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsDead}" Value="True">
                                        <Setter Property="TextColor" Value="{StaticResource AfAlertRed}" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Label" Binding="{Binding IsDead}" Value="False">
                                        <Setter Property="TextColor" Value="{StaticResource AfTerminalGreen}" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                            <Button Grid.Column="2" Text="REVIVE"
                                    FontSize="10" Padding="10,3"
                                    BackgroundColor="{StaticResource AfTerminalGreen}"
                                    TextColor="{StaticResource AfTextOnAccent}"
                                    ToolTipProperties.Text="Bring this NPC back (alive + default script phase). Most dead entries are story-scripted departures, so reviving may resurrect an actor the plot already moved elsewhere."
                                    IsVisible="{Binding CanRevive}"
                                    Clicked="OnReviveNpc"
                                    VerticalOptions="Center" />
                            <Label Grid.Column="3" Text="SCRIPT PHASE" Style="{StaticResource AfFieldLabel}" FontSize="8"
                                   ToolTipProperties.Text="Game-internal dialogue/script phase (0-5), not quest progress. Every living NPC sits at 3."
                                   VerticalOptions="Center" />
                            <Picker Grid.Column="4"
                                    ItemsSource="{Binding StateOptions}"
                                    SelectedItem="{Binding State, Mode=TwoWay}"
                                    FontSize="11"
                                    VerticalOptions="Center" />
                        </Grid>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </Border>

        <Label Text="Looking for traders? They moved to the metadata save's TRADERS tab, where you can unlock their stock world-wide."
               Style="{StaticResource AfMuted}" FontSize="10" />
    </VerticalStackLayout>
</ContentView>
