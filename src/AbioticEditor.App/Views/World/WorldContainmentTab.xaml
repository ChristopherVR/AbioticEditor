<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:items="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             xmlns:loc="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.World.WorldContainmentTab"
             x:DataType="vm:MainViewModel">

    <!-- ============== TAB: Containment + world unlocks (metadata save) ============== -->
    <Border BackgroundColor="{StaticResource AfShellBackground}"
            Stroke="{StaticResource AfBorderSubtleBrush}"
            StrokeThickness="1" StrokeShape="Rectangle"
            Padding="20,16"

            IsVisible="{Binding WorldEditor.IsContainmentTab}">
        <VerticalStackLayout Spacing="16">

            <!-- Leyak / Krasue containment units -->
            <Label Text="{loc:Localize WorldContainment_ContainmentUnits}" Style="{StaticResource AfH2}" FontSize="18" />
            <Label Text="{loc:Localize WorldContainment_ContainmentUnitsIntro}"
                   Style="{StaticResource AfMuted}" FontSize="11" LineBreakMode="WordWrap" />

            <Label Text="{loc:Localize WorldContainment_NothingContained}"
                   Style="{StaticResource AfStatusText}" FontSize="11"
                   IsVisible="{Binding WorldEditor.HasLeyakContainments, Converter={StaticResource BoolNegate}, FallbackValue=False}" />

            <VerticalStackLayout Spacing="8"
                                 BindableLayout.ItemsSource="{Binding WorldEditor.LeyakContainments}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="items:LeyakContainmentViewModel">
                        <!-- Row header + its own inline detail, so the image/info expands
                             directly under the entry the user tapped (not at the list foot). -->
                        <VerticalStackLayout Spacing="0">
                            <Border BackgroundColor="{StaticResource AfPanelBackground}"
                                    Stroke="{StaticResource AfBorderSubtleBrush}"
                                    StrokeThickness="1" StrokeShape="Rectangle"
                                    Padding="12,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="OnContainmentTapped" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                    <Border Grid.Column="0"
                                            BackgroundColor="{StaticResource AfTerminalGreenDim}"
                                            StrokeThickness="0" StrokeShape="Rectangle"
                                            Padding="8,3" VerticalOptions="Center">
                                        <Label Text="{loc:Localize WorldContainment_Contained}"
                                               FontFamily="OpenSansSemibold" FontSize="9"
                                               CharacterSpacing="2"
                                               TextColor="{StaticResource AfTextPrimary}" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                        <Label Text="{Binding ShownName}"
                                               Style="{StaticResource AfFieldValue}" FontSize="13" />
                                        <Label Text="{Binding ShownTapHint}"
                                               Style="{StaticResource AfStatusText}" FontSize="8" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="2" Text="{loc:Localize WorldContainment_Release}"
                                            FontSize="10" Padding="12,4"
                                            BackgroundColor="{StaticResource AfAlertRed}"
                                            TextColor="{StaticResource AfTextOnAccent}"
                                            ToolTipProperties.Text="{loc:Localize WorldContainment_ReleaseTooltip}"
                                            Command="{Binding ReleaseCommand}"
                                            VerticalOptions="Center" />
                                </Grid>
                            </Border>

                            <!-- Inline detail for THIS containment (expands on tap) -->
                            <Border BackgroundColor="{StaticResource AfPanelBackground}"
                                    Stroke="{StaticResource AfAmberBrush}"
                                    StrokeThickness="1" StrokeShape="Rectangle"
                                    Margin="0,6,0,0" Padding="16,12"
                                    IsVisible="{Binding IsExpanded}">
                                <Grid ColumnDefinitions="140,*" ColumnSpacing="16">
                                    <VerticalStackLayout Grid.Column="0" Spacing="3" VerticalOptions="Start">
                                        <Border WidthRequest="136" HeightRequest="136"
                                                BackgroundColor="#000000"
                                                StrokeThickness="0" StrokeShape="Rectangle" Padding="2">
                                            <Image Source="{Binding ImagePath}"
                                                   Aspect="AspectFit"
                                                   IsVisible="{Binding HasImage}" />
                                        </Border>
                                        <Label Text="Image: abioticfactor.wiki.gg"
                                               Style="{StaticResource AfMuted}" FontSize="8"
                                               IsVisible="{Binding ImageIsWiki}" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="1" Spacing="6">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Grid.Column="0"
                                                   Text="{Binding ShownDisplayName}"
                                                   Style="{StaticResource AfH2}" FontSize="16" VerticalOptions="Center" />
                                            <Button Grid.Column="1" Text="✕"
                                                    FontSize="11" Padding="8,2" VerticalOptions="Start"
                                                    BackgroundColor="{StaticResource AfPanelElevated}"
                                                    TextColor="{StaticResource AfTextPrimary}"
                                                    Clicked="OnCloseContainmentDetail" />
                                        </Grid>
                                        <Label Text="{Binding ShownLore}"
                                               Style="{StaticResource AfFieldValue}" FontSize="12" LineBreakMode="WordWrap" />
                                        <Label Text="{loc:Localize WorldContainment_ContainedIn}" Style="{StaticResource AfFieldLabel}" />
                                        <!-- Place name in a legible body font; only the numeric coordinates
                                             stay in the Digital7 LCD readout (where letters were unreadable). -->
                                        <Label Text="{Binding RegionText}"
                                               Style="{StaticResource AfFieldValue}" FontSize="14" LineBreakMode="WordWrap" />
                                        <Label Text="{Binding CoordsText}"
                                               Style="{StaticResource AfReadout}" FontSize="13"
                                               IsVisible="{Binding HasCoords}" />
                                        <Label Text="{Binding ContainingSaveText}"
                                               Style="{StaticResource AfStatusText}" FontSize="10"
                                               IsVisible="{Binding HasContainingSave}"
                                               LineBreakMode="WordWrap" />
                                        <Label Text="{Binding ContainmentId, StringFormat='Containment unit GUID: {0}'}"
                                               Style="{StaticResource AfStatusText}" FontSize="9"
                                               LineBreakMode="MiddleTruncation" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <BoxView Style="{StaticResource AfDivider}" />

            <!-- World-wide discovery (GlobalUnlocks): shared by every player in the world -->
            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding WorldEditor.HasWorldUnlocks, FallbackValue=False}">
                <Label Text="{loc:Localize WorldContainment_WorldUnlocks}" Style="{StaticResource AfH2}" FontSize="18" />
                <Label Text="{loc:Localize WorldContainment_WorldUnlocksIntro}"
                       Style="{StaticResource AfMuted}" FontSize="11" LineBreakMode="WordWrap" />

                <Grid ColumnDefinitions="160,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10" ColumnSpacing="16">
                    <Label Grid.Row="0" Grid.Column="0" Text="{loc:Localize WorldContainment_ItemsSeen}" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Label Grid.Row="0" Grid.Column="1" Text="{Binding WorldEditor.WorldItemsSeenText}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" />
                    <Button Grid.Row="0" Grid.Column="2" Text="{loc:Localize WorldContainment_DiscoverAll}"
                            FontSize="10" Padding="10,4"
                            BackgroundColor="{StaticResource AfPanelElevated}"
                            TextColor="{StaticResource AfTextPrimary}"
                            Clicked="OnUnlockAllWorldItems" />

                    <Label Grid.Row="1" Grid.Column="0" Text="{loc:Localize WorldContainment_EmailsRead}" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Label Grid.Row="1" Grid.Column="1" Text="{Binding WorldEditor.WorldEmailsText}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" />
                    <Button Grid.Row="1" Grid.Column="2" Text="{loc:Localize WorldContainment_ReadAll}"
                            FontSize="10" Padding="10,4"
                            BackgroundColor="{StaticResource AfPanelElevated}"
                            TextColor="{StaticResource AfTextPrimary}"
                            Clicked="OnUnlockAllWorldEmails" />

                    <Label Grid.Row="2" Grid.Column="0" Text="{loc:Localize WorldContainment_JournalPages}" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Label Grid.Row="2" Grid.Column="1" Text="{Binding WorldEditor.WorldJournalsText}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" />
                    <Button Grid.Row="2" Grid.Column="2" Text="{loc:Localize WorldContainment_FindAll}"
                            FontSize="10" Padding="10,4"
                            BackgroundColor="{StaticResource AfPanelElevated}"
                            TextColor="{StaticResource AfTextPrimary}"
                            Clicked="OnUnlockAllWorldJournals" />

                    <Label Grid.Row="3" Grid.Column="0" Text="{loc:Localize WorldContainment_Compendium}" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                    <Label Grid.Row="3" Grid.Column="1" Text="{Binding WorldEditor.WorldCompendiumText}"
                           Style="{StaticResource AfReadout}" VerticalOptions="Center" />
                    <Button Grid.Row="3" Grid.Column="2" Text="{loc:Localize WorldContainment_UnlockAll}"
                            FontSize="10" Padding="10,4"
                            BackgroundColor="{StaticResource AfHazardYellow}"
                            TextColor="{StaticResource AfTextOnAccent}"
                            Clicked="OnUnlockAllWorldCompendium" />
                </Grid>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Border>
</ContentView>
