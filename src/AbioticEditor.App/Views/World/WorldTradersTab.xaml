<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:items="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             xmlns:loc="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.World.WorldTradersTab"
             x:DataType="vm:MainViewModel">

    <!-- ============== TAB: Traders (metadata save) ============== -->
    <Border BackgroundColor="{StaticResource AfShellBackground}"
            Stroke="{StaticResource AfBorderSubtleBrush}"
            StrokeThickness="1" StrokeShape="Rectangle"
            Padding="20,16"

            IsVisible="{Binding WorldEditor.IsTradersTab}">
        <VerticalStackLayout Spacing="14">
            <Label Text="{loc:Localize WorldTraders_Traders}" Style="{StaticResource AfH2}" FontSize="18" />
            <Label Text="{loc:Localize WorldTraders_TradersIntro}"
                   Style="{StaticResource AfMuted}" FontSize="11" />
            <BoxView Style="{StaticResource AfDivider}" />

            <!-- Empty state: the roster is asset-only, so a blank list means the game's
                 pak data could not be loaded. Explain it and point at Settings. -->
            <Border BackgroundColor="{StaticResource AfPanelBackground}"
                    Stroke="{StaticResource AfBorderSubtleBrush}"
                    StrokeThickness="1" StrokeShape="Rectangle"
                    Padding="16,14"
                    IsVisible="{Binding WorldEditor.HasNoTraderData}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="{loc:Localize WorldTraders_NoDataTitle}"
                           Style="{StaticResource AfFieldLabel}"
                           TextColor="{StaticResource AfAccentOrange}"
                           CharacterSpacing="2" />
                    <Label Text="{loc:Localize WorldTraders_NoDataBody}"
                           Style="{StaticResource AfMuted}" FontSize="11"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <CollectionView ItemsSource="{Binding WorldEditor.TraderCards}" SelectionMode="None"
                            IsVisible="{Binding WorldEditor.HasTraderCards}">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="10" VerticalItemSpacing="10" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="items:TraderCardViewModel">
                        <Border BackgroundColor="{StaticResource AfPanelBackground}"
                                Stroke="{StaticResource AfBorderSubtleBrush}"
                                StrokeThickness="1" StrokeShape="Rectangle"
                                Padding="12,10">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer NumberOfTapsRequired="1" Tapped="OnTraderCardTapped" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="86,*" ColumnSpacing="12">
                                <Border Grid.Column="0" WidthRequest="82" HeightRequest="82"
                                        BackgroundColor="{StaticResource AfPanelElevated}"
                                        StrokeThickness="0" StrokeShape="Rectangle" Padding="2"
                                        VerticalOptions="Start">
                                    <Image Source="{Binding PortraitPath}" Aspect="AspectFit"
                                           IsVisible="{Binding ShowPortrait}" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="3">
                                    <Label Text="{Binding ShownName}" Style="{StaticResource AfH2}" FontSize="14" />
                                    <Label Text="{Binding ShownWhere}" Style="{StaticResource AfStatusText}" FontSize="10" LineBreakMode="WordWrap" />
                                    <Label Text="{Binding ShownBlurb}" Style="{StaticResource AfMuted}" FontSize="10" LineBreakMode="WordWrap" />
                                    <Label Text="{Binding ShownSellsText, StringFormat='Sells: {0}'}"
                                           Style="{StaticResource AfFieldValue}" FontSize="10" LineBreakMode="WordWrap"
                                           IsVisible="{Binding ShownSellsText, Converter={StaticResource NullToBoolConverter}}" />
                                    <Label Text="{Binding ShownAvailabilityText}"
                                           Style="{StaticResource AfStatusText}" FontSize="9"
                                           TextColor="{StaticResource AfAccentOrange}"
                                           LineBreakMode="WordWrap" />
                                    <Label Text="{Binding ShownTapHint}"
                                           Style="{StaticResource AfStatusText}" FontSize="8"
                                           TextColor="{StaticResource AfAmber}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </Border>
</ContentView>
