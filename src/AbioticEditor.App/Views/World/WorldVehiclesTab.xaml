<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:items="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.World.WorldVehiclesTab"
             x:Name="Root"
             x:DataType="vm:MainViewModel">

    <!-- ============== TAB: Vehicles (VehicleMap) ============== -->
    <VerticalStackLayout Spacing="12" IsVisible="{Binding WorldEditor.IsVehiclesTab}">
        <Label Text="VEHICLES IN THIS WORLD" Style="{StaticResource AfH2}" FontSize="18" />
        <Label Text="Click a vehicle to edit it: toggle whether it is drivable (unlocked) or wrecked, move it, reset it to its original spawn position, or open its on-board storage. Edits stage until SAVE; every write keeps a .bak."
               Style="{StaticResource AfMuted}" FontSize="11" />

        <controls:AdaptiveGrid ColumnDefinitions="2*,3*" ColumnSpacing="16" HeightRequest="620"
                               StackedChildHeight="440">
            <!-- Master list -->
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource AfShellBackground}"
                    Stroke="{StaticResource AfBorderSubtleBrush}"
                    StrokeThickness="1" StrokeShape="Rectangle"
                    Padding="0">
                <CollectionView ItemsSource="{Binding WorldEditor.VehicleGroups}"
                                IsGrouped="True"
                                SelectionMode="Single"
                                SelectedItem="{Binding WorldEditor.SelectedVehicle, Mode=TwoWay}">
                    <CollectionView.EmptyView>
                        <Label Text="No vehicles in this save (vehicles live in region saves)." Style="{StaticResource AfMuted}" Padding="16" />
                    </CollectionView.EmptyView>
                    <CollectionView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="items:VehicleWorldGroup">
                            <Grid BackgroundColor="{StaticResource AfPanelElevated}" Padding="12,6" ColumnDefinitions="*,Auto">
                                <Label Grid.Column="0" Text="{Binding World}"
                                       Style="{StaticResource AfFieldLabel}" FontSize="11"
                                       TextColor="{DynamicResource AfTerminalGreen}" VerticalOptions="Center" />
                                <Label Grid.Column="1" Text="{Binding CountText}"
                                       Style="{StaticResource AfStatusText}" FontSize="9" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.GroupHeaderTemplate>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="items:WorldVehicleViewModel">
                            <Grid Padding="12,8" ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                <VerticalStackLayout Grid.Column="0" Spacing="1" VerticalOptions="Center">
                                    <Label Text="{Binding DisplayName}" Style="{StaticResource AfFieldValue}" FontSize="13"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="Display only" Style="{StaticResource AfStatusText}" FontSize="9"
                                           IsVisible="{Binding IsDisplayOnly}" />
                                </VerticalStackLayout>
                                <Label Grid.Column="1" Text="{Binding StateText}"
                                       Style="{StaticResource AfFieldLabel}" FontSize="9" VerticalOptions="Center"
                                       IsVisible="{Binding IsEditable}" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <!-- Detail editor -->
            <Border Grid.Column="1"
                    BackgroundColor="{StaticResource AfShellBackground}"
                    Stroke="{StaticResource AfBorderSubtleBrush}"
                    StrokeThickness="1" StrokeShape="Rectangle"
                    Padding="18,14">
                <Grid>
                    <Label Text="Select a vehicle to edit it."
                           Style="{StaticResource AfMuted}"
                           IsVisible="{Binding WorldEditor.HasSelectedVehicle, Converter={StaticResource BoolNegate}}" />
                    <ScrollView IsVisible="{Binding WorldEditor.HasSelectedVehicle}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="{Binding WorldEditor.SelectedVehicle.DisplayName}"
                                   Style="{StaticResource AfH2}" FontSize="18" />
                            <Label Text="{Binding WorldEditor.SelectedVehicle.Region, StringFormat='World: {0}'}"
                                   Style="{StaticResource AfStatusText}" />
                            <Label Text="Display only - this vehicle has no editable drivable / wrecked / move state."
                                   Style="{StaticResource AfMuted}" FontSize="10" LineBreakMode="WordWrap"
                                   IsVisible="{Binding WorldEditor.SelectedVehicle.IsDisplayOnly, FallbackValue=False}" />

                            <!-- Appearance (abioticfactor.wiki.gg) -->
                            <HorizontalStackLayout Spacing="8"
                                                   IsVisible="{Binding WorldEditor.SelectedVehicle.IsWikiImageLoading, FallbackValue=False}">
                                <ActivityIndicator IsRunning="True" WidthRequest="16" HeightRequest="16" />
                                <Label Text="Fetching image from the wiki..." Style="{StaticResource AfMuted}" FontSize="10" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            <VerticalStackLayout Spacing="3"
                                                 IsVisible="{Binding WorldEditor.SelectedVehicle.HasWikiImage, FallbackValue=False}">
                                <Border BackgroundColor="#000000" StrokeThickness="0" StrokeShape="RoundRectangle 4"
                                        HeightRequest="150" Padding="10">
                                    <Image Source="{Binding WorldEditor.SelectedVehicle.WikiImagePath}" Aspect="AspectFit" />
                                </Border>
                                <Label Text="Image: abioticfactor.wiki.gg" Style="{StaticResource AfMuted}" FontSize="8" />
                            </VerticalStackLayout>

                            <!-- Editable controls: hidden for display-only vehicles (Sleigh, Tram, Minecart) -->
                            <VerticalStackLayout Spacing="12"
                                                 IsVisible="{Binding WorldEditor.SelectedVehicle.IsEditable, FallbackValue=False}">
                                <BoxView Style="{StaticResource AfDivider}" />

                                <!-- State: drivable (unlock) + wrecked -->
                                <Label Text="STATE" Style="{StaticResource AfFieldLabel}" TextColor="{DynamicResource AfTerminalGreen}" />
                                <HorizontalStackLayout Spacing="28">
                                    <HorizontalStackLayout Spacing="2">
                                        <CheckBox IsChecked="{Binding WorldEditor.SelectedVehicle.Driveable, Mode=TwoWay}"
                                                  Color="{StaticResource AfTerminalGreen}"
                                                  WidthRequest="30" VerticalOptions="Center" />
                                        <Label Text="DRIVABLE (UNLOCKED)" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="2">
                                        <CheckBox IsChecked="{Binding WorldEditor.SelectedVehicle.Destroyed, Mode=TwoWay}"
                                                  Color="{StaticResource AfAlertRed}"
                                                  WidthRequest="30" VerticalOptions="Center" />
                                        <Label Text="WRECKED" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>

                                <BoxView Style="{StaticResource AfDivider}" />

                                <!-- Location + move + reset -->
                                <Label Text="LOCATION" Style="{StaticResource AfFieldLabel}" TextColor="{DynamicResource AfHazardYellow}" />
                                <HorizontalStackLayout Spacing="8"
                                                       IsVisible="{Binding WorldEditor.SelectedVehicle.HasArea, FallbackValue=False}">
                                    <Label Text="AREA" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    <Label Text="{Binding WorldEditor.SelectedVehicle.AreaName}"
                                           Style="{StaticResource AfReadout}" FontSize="12" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Grid ColumnDefinitions="Auto,*,Auto,*,Auto,*" ColumnSpacing="8">
                                    <Label Grid.Column="0" Text="X" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    <Entry Grid.Column="1" Text="{Binding WorldEditor.SelectedVehicle.X, Mode=TwoWay}"
                                           Keyboard="Numeric" FontSize="12"
                                           BackgroundColor="{StaticResource AfPanelElevated}" TextColor="{StaticResource AfTextPrimary}" />
                                    <Label Grid.Column="2" Text="Y" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    <Entry Grid.Column="3" Text="{Binding WorldEditor.SelectedVehicle.Y, Mode=TwoWay}"
                                           Keyboard="Numeric" FontSize="12"
                                           BackgroundColor="{StaticResource AfPanelElevated}" TextColor="{StaticResource AfTextPrimary}" />
                                    <Label Grid.Column="4" Text="Z" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    <Entry Grid.Column="5" Text="{Binding WorldEditor.SelectedVehicle.Z, Mode=TwoWay}"
                                           Keyboard="Numeric" FontSize="12"
                                           BackgroundColor="{StaticResource AfPanelElevated}" TextColor="{StaticResource AfTextPrimary}" />
                                </Grid>
                                <Label Text="{Binding WorldEditor.SelectedVehicle.SpawnStatusText}"
                                       Style="{StaticResource AfMuted}" FontSize="10" />
                                <Button Text="RESET TO SPAWN" FontSize="10" Padding="10,4" HorizontalOptions="Start"
                                        BackgroundColor="{StaticResource AfHazardYellow}"
                                        TextColor="{StaticResource AfTextOnAccent}"
                                        Command="{Binding WorldEditor.SelectedVehicle.ResetToSpawnCommand}" />
                            </VerticalStackLayout>

                            <!-- Display-only vehicles: show the position read-only, no edit affordances -->
                            <VerticalStackLayout Spacing="6"
                                                 IsVisible="{Binding WorldEditor.SelectedVehicle.IsDisplayOnly, FallbackValue=False}">
                                <BoxView Style="{StaticResource AfDivider}" />
                                <Label Text="LOCATION" Style="{StaticResource AfFieldLabel}" TextColor="{DynamicResource AfHazardYellow}" />
                                <HorizontalStackLayout Spacing="8"
                                                       IsVisible="{Binding WorldEditor.SelectedVehicle.HasArea, FallbackValue=False}">
                                    <Label Text="AREA" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    <Label Text="{Binding WorldEditor.SelectedVehicle.AreaName}"
                                           Style="{StaticResource AfReadout}" FontSize="12" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding WorldEditor.SelectedVehicle.LocationText}"
                                       Style="{StaticResource AfReadout}" FontSize="13" />
                            </VerticalStackLayout>

                            <BoxView Style="{StaticResource AfDivider}" />

                            <!-- Inventory -->
                            <Label Text="ON-BOARD STORAGE" Style="{StaticResource AfFieldLabel}" />
                            <Label Text="{Binding WorldEditor.SelectedVehicle.InventoryText}"
                                   Style="{StaticResource AfFieldValue}" FontSize="12" />
                            <Button Text="OPEN INVENTORY (CONTAINERS TAB)" FontSize="10" Padding="10,4" HorizontalOptions="Start"
                                    BackgroundColor="{StaticResource AfTerminalGreen}"
                                    TextColor="{StaticResource AfTextOnAccent}"
                                    IsVisible="{Binding WorldEditor.SelectedVehicle.HasInventory, FallbackValue=False}"
                                    Command="{Binding WorldEditor.SelectedVehicle.OpenInventoryCommand}" />
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </controls:AdaptiveGrid>
    </VerticalStackLayout>
</ContentView>
