<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:items="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.World.WorldPetsTab"
             x:Name="Root"
             x:DataType="vm:MainViewModel">

    <!-- ============== TAB: Pets (PetNPC) ============== -->
    <VerticalStackLayout Spacing="12" IsVisible="{Binding WorldEditor.IsPetsTab}">
        <Label Text="TAMED PETS IN THIS WORLD" Style="{StaticResource AfH2}" FontSize="18" />
        <Label Text="Click a pet to edit it: rename, heal / down / revive, set level (XP), or change its creature type (the game's mutation - e.g. a Pest into another Pest, Peccary, or Skink variant). Delete removes it from the world. Armor-set summons (Exor, Mystagogue) are shown but not editable. Edits stage until SAVE; every write keeps a .bak."
               Style="{StaticResource AfMuted}" FontSize="11" />

        <!-- Master list + detail editor (stacks vertically on narrow widths) -->
        <controls:AdaptiveGrid ColumnDefinitions="2*,3*" ColumnSpacing="16" HeightRequest="620"
                               StackedChildHeight="440">
            <!-- Master list -->
            <Border Grid.Column="0"
                    BackgroundColor="{StaticResource AfShellBackground}"
                    Stroke="{StaticResource AfBorderSubtleBrush}"
                    StrokeThickness="1" StrokeShape="Rectangle"
                    Padding="0">
                <CollectionView ItemsSource="{Binding WorldEditor.Pets}"
                                SelectionMode="Single"
                                SelectedItem="{Binding WorldEditor.SelectedPet, Mode=TwoWay}">
                    <CollectionView.EmptyView>
                        <Label Text="No pets in this world save." Style="{StaticResource AfMuted}" Padding="16" />
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="items:WorldPetViewModel">
                            <Grid Padding="12,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <Border Grid.Column="0" WidthRequest="34" HeightRequest="34"
                                        BackgroundColor="{StaticResource AfTerminalGreenDim}"
                                        StrokeThickness="0" StrokeShape="RoundRectangle 6"
                                        VerticalOptions="Center">
                                    <Grid>
                                        <Label Text="{Binding Avatar}"
                                               FontFamily="OpenSansSemibold" FontSize="15"
                                               TextColor="{StaticResource AfTextPrimary}"
                                               HorizontalOptions="Center" VerticalOptions="Center" />
                                        <!-- Thumbnail appears once the portrait has been extracted. -->
                                        <Image Source="{Binding ImagePath}" Aspect="AspectFill"
                                               IsVisible="{Binding HasImage}" />
                                    </Grid>
                                </Border>
                                <VerticalStackLayout Grid.Column="1" Spacing="1" VerticalOptions="Center">
                                    <Label Text="{Binding DisplayName}" Style="{StaticResource AfFieldValue}" FontSize="13"
                                           LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding FriendlyClass}" Style="{StaticResource AfStatusText}" FontSize="10"
                                           LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <Label Grid.Column="2" Text="{Binding StatusText}"
                                       Style="{StaticResource AfFieldLabel}" FontSize="9" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>

            <!-- Detail editor -->
            <Border Grid.Column="1"
                    BackgroundColor="{StaticResource AfShellBackground}"
                    Stroke="{StaticResource AfBorderSubtleBrush}"
                    StrokeThickness="1" StrokeShape="Rectangle"
                    Padding="18,14">
                <Grid>
                    <Label Text="Select a pet to edit it."
                           Style="{StaticResource AfMuted}"
                           IsVisible="{Binding WorldEditor.HasSelectedPet, Converter={StaticResource BoolNegate}}" />
                    <ScrollView IsVisible="{Binding WorldEditor.HasSelectedPet}">
                        <VerticalStackLayout Spacing="12">
                            <Label Text="{Binding WorldEditor.SelectedPet.DisplayName}"
                                   Style="{StaticResource AfH2}" FontSize="18" />
                            <Label Text="{Binding WorldEditor.SelectedPet.FriendlyClass}"
                                   Style="{StaticResource AfStatusText}" />

                            <!-- Location: pets store only world coordinates, so we show those plus the
                                 region name when the host has supplied the world-save file name. -->
                            <VerticalStackLayout Spacing="2">
                                <Label Text="LOCATION" Style="{StaticResource AfFieldLabel}" />
                                <Label Text="{Binding WorldEditor.SelectedPet.LocationText}"
                                       Style="{StaticResource AfMuted}" FontSize="11" />
                            </VerticalStackLayout>

                            <!-- Appearance: the in-game bestiary portrait for this creature -->
                            <Border BackgroundColor="#000000" StrokeThickness="0" StrokeShape="RoundRectangle 4"
                                    HeightRequest="170" Padding="10" HorizontalOptions="Fill"
                                    IsVisible="{Binding WorldEditor.SelectedPet.HasImage, FallbackValue=False}">
                                <Image Source="{Binding WorldEditor.SelectedPet.ImagePath}" Aspect="AspectFit" />
                            </Border>

                            <!-- Summon notice -->
                            <Border BackgroundColor="{StaticResource AfPanelElevated}"
                                    StrokeThickness="0" StrokeShape="RoundRectangle 4" Padding="10,6"
                                    IsVisible="{Binding WorldEditor.SelectedPet.IsSummon, FallbackValue=False}">
                                <Label Text="This is an armor-set summon. It is shown for reference but is not editable."
                                       Style="{StaticResource AfMuted}" FontSize="10" />
                            </Border>

                            <!-- Name -->
                            <VerticalStackLayout Spacing="3"
                                                 IsVisible="{Binding WorldEditor.SelectedPet.IsEditable, FallbackValue=False}">
                                <Label Text="NAME" Style="{StaticResource AfFieldLabel}" />
                                <Entry Text="{Binding WorldEditor.SelectedPet.Name, Mode=TwoWay}"
                                       Placeholder="name your pet…"
                                       BackgroundColor="{StaticResource AfPanelElevated}"
                                       TextColor="{StaticResource AfTextPrimary}" />
                            </VerticalStackLayout>

                            <!-- Creature type (upgrade / downgrade / mutate) -->
                            <VerticalStackLayout Spacing="3"
                                                 IsVisible="{Binding WorldEditor.SelectedPet.IsEditable, FallbackValue=False}">
                                <Label Text="CREATURE TYPE (UPGRADE / DOWNGRADE)" Style="{StaticResource AfFieldLabel}" />
                                <Picker ItemsSource="{Binding WorldEditor.SelectedPet.VariantNames}"
                                        SelectedItem="{Binding WorldEditor.SelectedPet.SelectedVariantName, Mode=TwoWay}"
                                        BackgroundColor="{StaticResource AfPanelElevated}"
                                        TextColor="{StaticResource AfTextPrimary}" />
                                <Label Text="{Binding WorldEditor.SelectedPet.FamilyName, StringFormat='Family: {0}'}"
                                       Style="{StaticResource AfMuted}" FontSize="10" />
                            </VerticalStackLayout>

                            <BoxView Style="{StaticResource AfDivider}" />

                            <!-- Level / XP -->
                            <VerticalStackLayout Spacing="4"
                                                 IsVisible="{Binding WorldEditor.SelectedPet.IsEditable, FallbackValue=False}">
                                <Label Text="LEVEL &amp; XP" Style="{StaticResource AfFieldLabel}"
                                       TextColor="{DynamicResource AfHazardYellow}" />
                                <Grid ColumnDefinitions="Auto,*,Auto,110" ColumnSpacing="10">
                                    <Label Grid.Column="0" Text="LV" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    <Stepper Grid.Column="1"
                                             Minimum="0" Maximum="20" Increment="1"
                                             Value="{Binding WorldEditor.SelectedPet.Level, Mode=TwoWay}"
                                             VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="XP" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                    <Entry Grid.Column="3"
                                           Text="{Binding WorldEditor.SelectedPet.Xp, Mode=TwoWay}"
                                           Keyboard="Numeric"
                                           FontFamily="Digital7" FontSize="15"
                                           TextColor="{StaticResource AfTerminalGreen}"
                                           BackgroundColor="{StaticResource AfPanelElevated}"
                                           HorizontalTextAlignment="Center" />
                                </Grid>
                                <Label Text="{Binding WorldEditor.SelectedPet.Level, StringFormat='Level {0} of 20 (each level raises health, damage and size).'}"
                                       Style="{StaticResource AfMuted}" FontSize="10" />
                            </VerticalStackLayout>

                            <BoxView Style="{StaticResource AfDivider}" />

                            <!-- Life / health -->
                            <VerticalStackLayout Spacing="6"
                                                 IsVisible="{Binding WorldEditor.SelectedPet.IsEditable, FallbackValue=False}">
                                <Label Text="HEALTH" Style="{StaticResource AfFieldLabel}"
                                       TextColor="{DynamicResource AfTerminalGreen}" />
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="14">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding WorldEditor.SelectedPet.IsDead, Mode=TwoWay}"
                                              Color="{StaticResource AfAlertRed}" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="DEAD" Style="{StaticResource AfFieldLabel}"
                                           VerticalOptions="Center" />
                                    <Label Grid.Column="2" Text="{Binding WorldEditor.SelectedPet.StatusText}"
                                           Style="{StaticResource AfFieldValue}" FontSize="12" VerticalOptions="Center"
                                           HorizontalOptions="Start" />
                                    <Label Grid.Column="3"
                                           Text="{Binding WorldEditor.SelectedPet.TotalHealth, StringFormat='Total {0:0}'}"
                                           Style="{StaticResource AfMuted}" FontSize="11" VerticalOptions="Center" />
                                </Grid>
                                <HorizontalStackLayout Spacing="8">
                                    <Button Text="HEAL TO FULL" FontSize="10" Padding="10,4"
                                            BackgroundColor="{StaticResource AfTerminalGreen}"
                                            TextColor="{StaticResource AfTextOnAccent}"
                                            Command="{Binding WorldEditor.SelectedPet.HealCommand}" />
                                    <Button Text="DOWN" FontSize="10" Padding="10,4"
                                            BackgroundColor="{StaticResource AfHazardYellow}"
                                            TextColor="{StaticResource AfTextOnAccent}"
                                            Command="{Binding WorldEditor.SelectedPet.DownCommand}" />
                                    <Button Text="REVIVE" FontSize="10" Padding="10,4"
                                            BackgroundColor="{StaticResource AfTerminalGreen}"
                                            TextColor="{StaticResource AfTextOnAccent}"
                                            Command="{Binding WorldEditor.SelectedPet.ReviveCommand}" />
                                </HorizontalStackLayout>

                                <!-- Per-limb health -->
                                <VerticalStackLayout Spacing="4"
                                                     BindableLayout.ItemsSource="{Binding WorldEditor.SelectedPet.Limbs}">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="items:PetLimbViewModel">
                                            <Grid ColumnDefinitions="120,140" ColumnSpacing="10">
                                                <Label Grid.Column="0" Text="{Binding Label}"
                                                       Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                                <Entry Grid.Column="1"
                                                       Text="{Binding Value, Mode=TwoWay}"
                                                       Keyboard="Numeric" FontSize="12"
                                                       BackgroundColor="{StaticResource AfPanelElevated}"
                                                       TextColor="{StaticResource AfTextPrimary}" />
                                            </Grid>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                                <Label Text="Health is per-limb current HP. The blueprint maximum is not stored, so HEAL raises every used limb to the pet's strongest limb. A pet with all limbs at 0 is 'downed' (critically wounded)."
                                       Style="{StaticResource AfMuted}" FontSize="9" />
                            </VerticalStackLayout>

                            <BoxView Style="{StaticResource AfDivider}" />

                            <!-- Delete from world -->
                            <Button Text="DELETE PET FROM WORLD" FontSize="11" Padding="12,6"
                                    BackgroundColor="{StaticResource AfAlertRed}"
                                    TextColor="{StaticResource AfTextOnAccent}"
                                    Command="{Binding WorldEditor.SelectedPet.DeleteCommand}"
                                    IsVisible="{Binding WorldEditor.SelectedPet.IsDeleted, Converter={StaticResource BoolNegate}, FallbackValue=True}" />
                            <Button Text="UNDO DELETE" FontSize="11" Padding="12,6"
                                    BackgroundColor="{StaticResource AfHazardYellow}"
                                    TextColor="{StaticResource AfTextOnAccent}"
                                    Command="{Binding WorldEditor.SelectedPet.DeleteCommand}"
                                    IsVisible="{Binding WorldEditor.SelectedPet.IsDeleted, FallbackValue=False}" />

                            <!-- Move this pet into a player's inventory (cross-save) -->
                            <BoxView Style="{StaticResource AfDivider}" IsVisible="{Binding WorldEditor.HasSiblingPlayers}" />
                            <VerticalStackLayout Spacing="6" IsVisible="{Binding WorldEditor.HasSiblingPlayers}">
                                <Label Text="SEND TO A PLAYER" Style="{StaticResource AfFieldLabel}"
                                       TextColor="{DynamicResource AfTerminalGreen}" />
                                <Picker ItemsSource="{Binding WorldEditor.SiblingPlayers}"
                                        SelectedItem="{Binding WorldEditor.SelectedSiblingPlayer, Mode=TwoWay}"
                                        BackgroundColor="{StaticResource AfPanelElevated}" TextColor="{StaticResource AfTextPrimary}" />
                                <HorizontalStackLayout Spacing="6">
                                    <CheckBox IsChecked="{Binding WorldEditor.SendToCompanion, Mode=TwoWay}"
                                              Color="{StaticResource AfTerminalGreen}" />
                                    <Label Text="Companion slot (off = first free hotbar slot)"
                                           Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Button Text="SEND TO PLAYER" FontSize="11" Padding="12,6" HorizontalOptions="Start"
                                        BackgroundColor="{StaticResource AfTerminalGreen}" TextColor="{StaticResource AfTextOnAccent}"
                                        Command="{Binding WorldEditor.SendPetToPlayerCommand}" />
                                <Label Text="{Binding WorldEditor.PetMoveStatus}" Style="{StaticResource AfMuted}" FontSize="10"
                                       IsVisible="{Binding WorldEditor.PetMoveStatus, Converter={StaticResource NullToBoolConverter}, FallbackValue=False}" />
                                <Label Text="Health, level and name carry over; the pet leaves the world. Save other world edits first."
                                       Style="{StaticResource AfMuted}" FontSize="9" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </ScrollView>
                </Grid>
            </Border>
        </controls:AdaptiveGrid>
    </VerticalStackLayout>
</ContentView>
