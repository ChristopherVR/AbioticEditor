<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             xmlns:loc="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.World.WorldRawTab"
             x:DataType="vm:MainViewModel">

    <!-- ============== TAB: Raw JSON (export/import) ============== -->
    <VerticalStackLayout Spacing="14"
                         IsVisible="{Binding WorldEditor.IsRawTab}">
        <Label Text="{loc:Localize WorldRaw_RawSaveJson}" Style="{StaticResource AfH2}" FontSize="18" />
        <Label Text="{loc:Localize WorldRaw_RawJsonIntro}"
               Style="{StaticResource AfMuted}" FontSize="12" />
        <Label Text="{Binding WorldEditor.JsonPath, StringFormat='JSON file: {0}'}"
               Style="{StaticResource AfStatusText}" />
        <HorizontalStackLayout Spacing="12">
            <Button Text="{loc:Localize WorldRaw_ExportJsonOpen}"
                    Command="{Binding WorldEditor.ExportJsonCommand}" />
            <Button Text="{loc:Localize WorldRaw_ImportJsonSave}"
                    BackgroundColor="{StaticResource AfAccentOrange}"
                    TextColor="{StaticResource AfTextOnAccent}"
                    Command="{Binding WorldEditor.ImportJsonCommand}" />
            <ActivityIndicator IsRunning="{Binding WorldEditor.IsSaving}"
                               IsVisible="{Binding WorldEditor.IsSaving}"
                               WidthRequest="18" HeightRequest="18" VerticalOptions="Center" />
        </HorizontalStackLayout>
        <Label Text="{Binding WorldEditor.RawStatus}"
               Style="{StaticResource AfReadout}" FontSize="13" />
    </VerticalStackLayout>
</ContentView>
