<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:AbioticEditor.App.ViewModels"
             xmlns:world="clr-namespace:AbioticEditor.App.Views.World"
             xmlns:controls="clr-namespace:AbioticEditor.App.Controls"
             xmlns:loc="clr-namespace:AbioticEditor.App.Controls"
             x:Class="AbioticEditor.App.Views.World.WorldEditorView"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding HasWorldEditor}">

    <!-- World save editor -->
    <Border Style="{StaticResource AfPanel}" Padding="20,16"
            controls:Fx.Reveal="True"
            IsVisible="{Binding HasWorldEditor}">
        <VerticalStackLayout Spacing="14">

            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                <Label Grid.Column="0" Text="{loc:Localize WorldEditor_WorldSave}" Style="{StaticResource AfH2}" VerticalOptions="Center" />
                <Label Grid.Column="1"
                       Text="{Binding WorldEditor.FileName}"
                       Style="{StaticResource AfStatusText}"
                       VerticalOptions="Center" />
            </Grid>

            <!-- Summary chips -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="24">
                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label Text="{loc:Localize WorldEditor_Containers}" Style="{StaticResource AfFieldLabel}" />
                    <Label Text="{Binding WorldEditor.ContainerCount}"
                           Style="{StaticResource AfReadout}" FontSize="18" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="1" Spacing="2">
                    <Label Text="{loc:Localize WorldEditor_WithContents}" Style="{StaticResource AfFieldLabel}" />
                    <Label Text="{Binding WorldEditor.NonEmptyCount}"
                           Style="{StaticResource AfReadout}" FontSize="18" />
                </VerticalStackLayout>
                <VerticalStackLayout Grid.Column="2" Spacing="2">
                    <Label Text="{loc:Localize WorldEditor_Status}" Style="{StaticResource AfFieldLabel}" />
                    <Label Text="{Binding WorldEditor.SaveStatus, FallbackValue='Ready'}"
                           Style="{StaticResource AfMuted}" FontSize="13" VerticalOptions="Center" />
                </VerticalStackLayout>
            </Grid>

            <!-- World clock (Facility save's TimeOfDay struct) -->
            <controls:AdaptiveGrid ColumnDefinitions="Auto,90,Auto,*,Auto" ColumnSpacing="12" CompactWidth="560"
                                   IsVisible="{Binding WorldEditor.HasWorldClock, FallbackValue=False}">
                <Label Grid.Column="0" Text="{loc:Localize WorldEditor_WorldDay}" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       Text="{Binding WorldEditor.WorldDay, Mode=TwoWay}"
                       Keyboard="Numeric"
                       FontFamily="Digital7" FontSize="16"
                       TextColor="{StaticResource AfTerminalGreen}"
                       HorizontalTextAlignment="Center" VerticalOptions="Center" />
                <Label Grid.Column="2" Text="{loc:Localize WorldEditor_TimeOfDay}" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                <Slider Grid.Column="3" Minimum="0" Maximum="86400"
                        Value="{Binding WorldEditor.WorldTimeSeconds, Mode=TwoWay}"
                        MinimumTrackColor="{StaticResource AfHazardYellow}"
                        MaximumTrackColor="{StaticResource AfPanelElevated}"
                        ThumbColor="{StaticResource AfTerminalGreen}"
                        VerticalOptions="Center" />
                <Label Grid.Column="4" Text="{Binding WorldEditor.WorldTimeText}"
                       Style="{StaticResource AfReadout}" FontSize="16" VerticalOptions="Center" />
            </controls:AdaptiveGrid>

            <!-- First-entered day (region saves) -->
            <Grid ColumnDefinitions="Auto,90,*" ColumnSpacing="12"
                  IsVisible="{Binding WorldEditor.HasDayDiscovered, FallbackValue=False}">
                <Label Grid.Column="0" Text="{loc:Localize WorldEditor_DayDiscovered}" Style="{StaticResource AfFieldLabel}" VerticalOptions="Center" />
                <Entry Grid.Column="1"
                       Text="{Binding WorldEditor.DayDiscovered, Mode=TwoWay}"
                       Keyboard="Numeric"
                       FontFamily="Digital7" FontSize="16"
                       TextColor="{StaticResource AfTerminalGreen}"
                       HorizontalTextAlignment="Center" VerticalOptions="Center" />
                <Label Grid.Column="2"
                       Text="{loc:Localize WorldEditor_DayDiscoveredHelp}"
                       Style="{StaticResource AfMuted}" FontSize="10" VerticalOptions="Center" />
            </Grid>

            <BoxView Style="{StaticResource AfHazardStripe}" />

            <!-- ===== Tab bar (wraps onto multiple rows so every tab stays visible) ===== -->
            <!-- The strip is one flat list (fixed tabs + one per applicable world-state
                 feature map + RAW JSON), built and filtered in the view-model; a wrapping
                 FlexLayout lays them across rows instead of overflowing a single line. -->
            <FlexLayout Wrap="Wrap" Direction="Row" AlignItems="Center"
                        BindableLayout.ItemsSource="{Binding WorldEditor.Tabs}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="vm:WorldTabButton">
                        <Button Text="{Binding Title}" Style="{StaticResource AfTabButton}"
                                Command="{Binding SelectCommand}"
                                Margin="0,0,4,4"
                                BackgroundColor="{Binding IsActive, Converter={StaticResource TabBrush}}" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </FlexLayout>

            <!-- Lazily realized per tab (see LazyView): only opened tabs join the live tree. -->
            <controls:LazyView IsActive="{Binding WorldEditor.IsDroppedTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldDroppedTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsPetsTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldPetsTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsVehiclesTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldVehiclesTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsBasesTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldBasesTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsMetaTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldStoryTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsTradersTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldTradersTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsContainmentTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldContainmentTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsContainersTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldContainersTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsFlagsTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldFlagsTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsDoorsTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldDoorsTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsFeatureTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldFeatureTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
            <controls:LazyView IsActive="{Binding WorldEditor.IsRawTab}">
                <controls:LazyView.ContentTemplate><DataTemplate><world:WorldRawTab /></DataTemplate></controls:LazyView.ContentTemplate>
            </controls:LazyView>
        </VerticalStackLayout>
    </Border>
</ContentView>
